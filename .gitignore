# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build.log

# Task summaries (session artifacts)
TASK-*.md

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Built effect modules (generated by build:effects)
/public/effects

# OpenNext
/.open-next

# wrangler files
.wrangler
.dev.vars*


!.dev.vars.example

# Generated types
cloudflare-env.d.ts

# Claude Code (all Claude files)
.claude/

# Legacy build artifacts
/dist
/.react-router
/preview
/meta

# Playwright test artifacts
/playwright-report
/test-results
/blob-report
/e2e/.auth
.playwright-auth.json

# Planning & session artifacts
.planning/
.sessions/
.design-audit/
.audit/

# Migrations (managed in Cloudflare D1 dashboard)
/migrations/*
!/migrations/0043_audit_log.sql

# Dev scripts & seed data (except build-public-effects which CI needs)
/scripts/*
!/scripts/build-public-effects.mjs
!/scripts/rehash-passwords.mjs
!/scripts/sbom.mjs

# E2E tests (not needed for launch)
/e2e

# Unused config files
.dockerignore
ARCHITECTURE.md
playwright.config.ts
vitest.config.ts

# IDE settings
.vscode/

# Stray directories (browser profiles, etc.)
UsersDannis*
