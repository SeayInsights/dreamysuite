# Copy to .env.local for local dev. NEXT_PUBLIC_* vars are exposed to the browser.

# V2 editor is now the default. Set this to 1/true/yes/on to fall back to legacy V1.
# NEXT_PUBLIC_EDITOR_V1_FALLBACK=

# Google Maps / Places API key. Used client-side (Maps JS) and server-side
# (Places Autocomplete + Details API routes). One key serves both purposes.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
