          <div class="section-rule" aria-hidden="true"></div>
          
          <form class="rsvp-form" id="rsvp-form-blk-rsvp-form" aria-label="RSVP form" onsubmit="submitRsvp(event,'test-slug','rsvp-form-blk-rsvp-form','rsvp-msg-blk-rsvp-form')">
