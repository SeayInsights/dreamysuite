exports[`renderBlock output parity > renders 'guest-book' identically 1`] = `
"
        <section class="block block-guest-book" aria-label="Guest Book" data-block-id="blk-guest-book" data-block-type="guest-book"
          style="max-width:600px;margin:0 auto;">
          <h2 class="section-heading">Guest Book</h2><div class="section-rule" aria-hidden="true"></div>
          <form class="rsvp-form" id="gb-form-blk-guest-book" onsubmit="submitGuestBook(event,'s1','gb-form-blk-guest-book','gb-list-blk-guest-book')">
            <div class="form-group">
              <label class="form-label" for="gb-name-blk-guest-book">Your Name</label>
              <input class="form-input" id="gb-name-blk-guest-book" name="name" type="text" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="gb-msg-blk-guest-book">Message</label>
              <textarea class="form-input form-textarea" id="gb-msg-blk-guest-book" name="message" placeholder="Leave a message for the happy couple…" required></textarea>
            </div>
            <button class="rsvp-submit" type="submit" style="background:var(--site-accent)">Sign the book</button>
          </form>
          <div id="gb-list-blk-guest-book" style="margin-top:1.5rem;display:flex;flex-direction:column;gap:0.75rem;"></div>
        </section>"
`;

