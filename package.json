{
  "name": "dreamysuite",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "react-router typegen && tsc",
    "db:migrate:local": "wrangler d1 migrations apply dreamysuite-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply dreamysuite-db"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@types/sortablejs": "^1.15.9",
    "better-auth": "^1.2.7",
    "isbot": "^5.1.36",
    "kysely": "^0.28.15",
    "kysely-d1": "^0.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250407.0",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wrangler": "^4.0.0"
  }
}
