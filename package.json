{
  "name": "dreamysuite",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build:effects": "node scripts/build-public-effects.mjs",
    "build": "node scripts/build-public-effects.mjs && next build --webpack",
    "start": "next start",
    "lint": "eslint src",
    "test": "vitest run",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "audit": "npm audit --audit-level=high",
    "sbom": "node scripts/sbom.mjs",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@sentry/browser": "^10.51.0",
    "@use-gesture/react": "^10.3.1",
    "better-auth": "^1.6.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.8.0",
    "maath": "^0.10.8",
    "meshline": "^3.3.1",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "ogl": "^1.0.11",
    "postprocessing": "^6.39.1",
    "preact": "^10.29.1",
    "react": "19.1.5",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.1.5",
    "sortablejs": "^1.15.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "zod": "^4.3.6",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260416.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19.1.5",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19.1.5",
    "@types/sortablejs": "^1.15.9",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{css,json,md}": "prettier --write"
  }
}
